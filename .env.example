# ── Frontend Environment Variables ───────────────────────────
# Copy this to .env.local — Vite loads it automatically.
# Variables must start with VITE_ to be accessible in the browser.

# URL of your Express API server
# Dev: http://localhost:3001  |  Prod: https://your-deployed-api.com
VITE_API_URL=http://localhost:3001

# Supabase — used for admin Dashboard sign-in.
# Get both values from: Supabase Dashboard → Project Settings → API
# Use the "anon / public" key (NOT the service_role key).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
